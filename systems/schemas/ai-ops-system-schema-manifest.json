{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AI-Ops Framework Manifest Schema",
  "version": "1.2",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "license",
    "model_format",
    "modules",
    "entrypoints",
    "integrity_rules",
    "ai_agent_governance"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "ai-ops-framework"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "GPL-3.0"]
    },
    "model_format": {
      "type": "string",
      "const": "framework"
    },
    "modules": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "use_cases",
        "starter_prompts",
        "documentation",
        "governance",
        "root_files",
        "schemas"
      ],
      "properties": {
        "workflows": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.(md|json)$" } },
        "templates": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.md$" } },
        "systems": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.(md|js)$" } },
        "use_cases": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.md$" } },
        "starter_prompts": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.md$" } },
        "documentation": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.md$" } },
        "governance": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.md$" } },
        "root_files": { "type": "array", "items": { "type": "string", "pattern": "^[^\\s]+$" } },
        "schemas": { "type": "array", "items": { "type": "string", "pattern": "^.*\\.json$" } }
      },
      "additionalProperties": false
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "use_cases",
        "starter_prompts",
        "documentation",
        "governance",
        "schemas",
        "root"
      ],
      "properties": {
        "workflows": { "type": "string", "pattern": "^\\./.*$" },
        "templates": { "type": "string", "pattern": "^\\./.*$" },
        "systems": { "type": "string", "pattern": "^\\./.*$" },
        "use_cases": { "type": "string", "pattern": "^\\./.*$" },
        "starter_prompts": { "type": "string", "pattern": "^\\./.*$" },
        "documentation": { "type": "string", "pattern": "^\\./.*$" },
        "governance": { "type": "string", "pattern": "^\\./.*$" },
        "schemas": { "type": "string", "pattern": "^\\./.*$" },
        "root": { "type": "string", "pattern": "^\\./.*$" }
      },
      "additionalProperties": false
    },
    "integrity_rules": {
      "type": "object",
      "required": [
        "naming_conventions",
        "alphabetical_ordering",
        "no_deprecated_files"
      ],
      "properties": {
        "naming_conventions": { "type": "string", "enum": ["snake_case"] },
        "alphabetical_ordering": { "type": "boolean" },
        "no_deprecated_files": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ai_agent_governance": {
      "type": "object",
      "required": ["strict_mode"],
      "properties": {
        "strict_mode": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}

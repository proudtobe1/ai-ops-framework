{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AI-Ops Framework Manifest Schema",
  "version": "1.2",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "license",
    "model_format",
    "modules",
    "entrypoints",
    "integrity_rules",
    "ai_agent_governance"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "ai-ops-framework"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "GPL-3.0"]
    },
    "model_format": {
      "type": "string",
      "const": "framework"
    },
    "modules": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "documentation",
        "governance",
        "root_files",
        "schemas"
      ],
      "properties": {
        "workflows": { "type": "array", "items": { "type": "string" } },
        "templates": { "type": "array", "items": { "type": "string" } },
        "systems": { "type": "array", "items": { "type": "string" } },
        "documentation": { "type": "array", "items": { "type": "string" } },
        "governance": { "type": "array", "items": { "type": "string" } },
        "root_files": { "type": "array", "items": { "type": "string" } },
        "schemas": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "documentation",
        "governance",
        "schemas",
        "root"
      ],
      "properties": {
        "workflows": { "type": "string" },
        "templates": { "type": "string" },
        "systems": { "type": "string" },
        "documentation": { "type": "string" },
        "governance": { "type": "string" },
        "schemas": { "type": "string" },
        "root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "integrity_rules": {
      "type": "object",
      "required": ["naming_conventions", "alphabetical_ordering", "no_deprecated_files"],
      "properties": {
        "naming_conventions": { "type": "string", "enum": ["kebab-case"] },
        "alphabetical_ordering": { "type": "boolean" },
        "no_deprecated_files": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ai_agent_governance": {
      "type": "object",
      "required": ["strict_mode"],
      "properties": {
        "strict_mode": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AI-Ops Framework Manifest Schema",
  "version": "1.2",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "license",
    "model_format",
    "modules",
    "entrypoints",
    "integrity_rules",
    "ai_agent_governance"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "ai-ops-framework"
    },
    "version": {
      "type": "string",
      "description": "Enforces strict Semantic Versioning (e.g., 1.0.4)",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "license": {
      "type": "string",
      "enum": [
        "MIT",
        "Apache-2.0",
        "GPL-3.0"
      ]
    },
    "model_format": {
      "type": "string",
      "const": "framework"
    },
    "modules": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "use_cases",
        "starter_prompts",
        "documentation",
        "governance",
        "root_files",
        "schemas"
      ],
      "properties": {
        "workflows": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "templates": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "systems": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "use_cases": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "starter_prompts": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "documentation": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "governance": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "root_files": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "schemas": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[^\\s]+$" },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "workflows",
        "templates",
        "systems",
        "use_cases",
        "starter_prompts",
        "documentation",
        "governance",
        "root"
      ],
      "properties": {
        "workflows": { "type": "string", "pattern": "^.*\\.json$" },
        "templates": { "type": "string", "pattern": "^.*\\.md$" },
        "systems": { "type": "string", "pattern": "^.*\\.md$" },
        "use_cases": { "type": "string", "pattern": "^.*\\.json$" },
        "starter_prompts": { "type": "string", "pattern": "^.*\\.md$" },
        "documentation": { "type": "string", "pattern": "^.*\\.md$" },
        "governance": { "type": "string", "pattern": "^.*\\.md$" },
        "root": { "type": "string", "pattern": "^.*\\.json$" }
      },
      "additionalProperties": false
    },
    "integrity_rules": {
      "type": "object",
      "required": [
        "naming_conventions",
        "alphabetical_ordering",
        "no_deprecated_files"
      ],
      "properties": {
        "naming_conventions": {
          "type": "string",
          "enum": [
            "snake_case"
          ]
        },
        "alphabetical_ordering": {
          "type": "boolean"
        },
        "no_deprecated_files": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ai_agent_governance": {
      "type": "object",
      "required": [
        "strict_mode"
      ],
      "properties": {
        "strict_mode": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}

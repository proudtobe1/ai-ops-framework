{
  "name": "ai-ops-framework",
  "version": "1.0.0",
  "description": "A modular AI-enabled operational framework for workflows, decisions, systems, prompts, and documentation.",
  "license": "MIT",
  "model_format": "framework",

  "modules": {
    "documentation": [
      "architecture-overview.md",
      "framework-goals.md",
      "glossary.md",
      "system-boundaries.md"
    ],
    "governance": [
      "ai-ops-governance-decision-rights.md",
      "ai-ops-governance-operating-rules.md",
      "ai-ops-governance-review-cadence.md"
    ],
    "root_files": [
      "CONTRIBUTING.md",
      "LICENSE",
      "README.md"
    ],
    "starter_prompts": [
      "prompt-agent-behavior.md",
      "prompt-agent-communication.md",
      "prompt-agent-decision-model.md",
      "prompt-agent-operating-model.md"
    ],
    "systems": [
      "ai-ops-system-alignment-engine.md",
      "ai-ops-system-behavioral-guardrails.md",
      "ai-ops-system-communication-cadence.md",
      "ai-ops-system-communication-engine.md",
      "ai-ops-system-drift-detection.md",
      "ai-ops-system-knowledge-model.md",
      "ai-ops-system-memory-context.md",
      "ai-ops-system-operational-metrics.md",
      "ai-ops-system-operating-model.md",
      "ai-ops-system-overview.md",
      "ai-ops-system-reasoning-framework.md",
      "ai-ops-system-security-compliance.md"
    ],
    "templates": [
      "ai-ops-template-decision-record.md",
      "ai-ops-template-escalation-record.md",
      "ai-ops-template-metrics-report.md",
      "ai-ops-template-status-update.md"
    ],
    "use_cases": [
    ],
    "workflows": [
      "ai-ops-workflow-drift-detection.md",
      "ai-ops-workflow-escalation.md",
      "ai-ops-workflow-metrics-review.md",
      "ai-ops-workflow-operating-rhythm.md",
      "ai-ops-workflow-status-update.md"
    ]
  },

  "entrypoints": {
    "workflows": "./workflows",
    "templates": "./templates",
    "systems": "./systems",
    "use_cases": "./use-cases",
    "starter_prompts": "./starter-prompts",
    "documentation": "./docs",
    "governance": "./",
    "root": "./"
  },

  "integrity_rules": {
    "naming_conventions": "All files must follow ai-ops-[type]-[name].md or prompt-[name].md",
    "alphabetical_ordering": true,
    "no_deprecated_files": true,
    "option_a_required": true
  },

  "ai_agent_governance": {
    "alignment_required": true,
    "drift_detection_enabled": true,
    "audit_logging": true,
    "human_in_the_loop_required": true
  }
}

  "entrypoints": {
    "root": "./",
    "documentation": "./docs",
    "governance": "./.github",
    "starter_prompts": "./docs/starter-prompts",
    "systems": "./systems",
    "templates": "./docs/templates",
    "use_cases": "./docs/use-cases",
    "workflows": "./systems/workflows"
  },
  "integrity_rules": {
    "naming_conventions": "All files must follow ai-ops-[type]-[name].md or prompt-[name].md",
    "alphabetical_ordering": true,
    "no_deprecated_files": true,
    "strict_manifest_sync": true
  },
  "ai_agent_governance": {
    "alignment_required": true,
    "drift_detection_enabled": true,
    "audit_logging": true,
    "human_in_the_loop_required": true
  }
}

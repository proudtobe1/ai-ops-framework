{
  "name": "ai-ops-framework",
  "version": "1.2.0",
  "description": "Machine-readable operational manifest and system registration registry.",
  "license": "MIT",
  "model_format": "framework",
  "modules": {
    "workflows": [
      "workflows/ai-ops-workflow-sample.md"
    ],
    "templates": [
      "templates/ai-ops-template-sample.md"
    ],
    "systems": [
      "systems/ai-ops-system-sample.md"
    ],
    "documentation": [
      "docs/index.md"
    ],
    "governance": [
      "PROJECT_GOVERNANCE.md"
    ],
    "root_files": [
      "README.md",
      "LICENSE",
      "mkdocs.yml"
    ],
    "schemas": [
      "systems/schemas/ai-ops-system-schema-manifest.json"
    ]
  },
  "entrypoints": {
    "workflows": "workflows/",
    "templates": "templates/",
    "systems": "systems/",
    "documentation": "docs/",
    "governance": "PROJECT_GOVERNANCE.md",
    "schemas": "systems/schemas/",
    "root": "README.md"
  },
  "integrity_rules": {
    "naming_conventions": "kebab-case",
    "alphabetical_ordering": true,
    "no_deprecated_files": true
  },
  "ai_agent_governance": {
    "strict_mode": true
  },
  "validation_vectors": [
    {
      "vector_id": 1,
      "name": "provenance_logging",
      "module": "validators/provenance_logger.py",
      "test": "tests/test_provenance_logger.py",
      "status": "active"
    },
    {
      "vector_id": 2,
      "name": "schema_enforcement",
      "module": "validators/schema_enforcer.py",
      "test": "tests/test_schema_enforcer.py",
      "status": "active"
    },
    {
      "vector_id": 3,
      "name": "judge_calibration",
      "module": "validators/judge_calibration.py",
      "test": "tests/test_judge_calibration.py",
      "status": "active"
    },
    {
      "vector_id": 4,
      "name": "seed_stability",
      "module": "validators/seed_stability.py",
      "test": "tests/test_seed_stability.py",
      "status": "active"
    },
    {
      "vector_id": 5,
      "name": "vector_drift",
      "module": "validators/vector_drift.py",
      "test": "tests/test_vector_drift.py",
      "status": "active"
    }
  ]
}

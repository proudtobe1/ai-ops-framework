      "PROJECT_GOVERNANCE.md",
      "PULL_REQUEST_TEMPLATE.md",
      "README.md"
    ],
    "root_files": [
      ".markdownlint.json",
      "LICENSE",
      "README.md",
      "ai-ops-manifest.json",
      "mkdocs.yml"
    ],
    "starter_prompts": [
      "README.md",
      "prompt-alignment-check.md",
      "prompt-decision-tree.md",
